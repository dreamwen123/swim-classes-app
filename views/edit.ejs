<h1>Edit Class: <%= swimClass.title %></h1>
<form action="/classes/<%= swimClass.id %>/edit" method="POST">
    <input type="text" name="title" value="<%= swimClass.title %>" required>
    <textarea name="description"><%= swimClass.description %></textarea>
    <select name="difficulty_level">
        <option value="Beginner" <%= swimClass.difficulty_level === 'Beginner' ? 'selected' : '' %>>Beginner</option>
        <option value="Intermediate" <%= swimClass.difficulty_level === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
    </select>
    <input type="number" step="0.01" name="price" value="<%= swimClass.price %>" required>
    <button type="submit">Update Class</button>
</form>